{
  "name": "employee-monitoring-system",
  "version": "1.1.11",
  "description": "Desktop employee monitoring application with screenshot capture",
  "author": "Your Company",
  "main": "desktop-app/main.js",
  "scripts": {
    "start:desktop": "electron desktop-app/main.js",
    "start:backend": "node backend/server.js",
    "start:frontend": "cd admin-dashboard && npm start",
    "dev:backend": "nodemon backend/server.js",
    "build:desktop": "electron-builder --win",
    "build:desktop:dir": "electron-builder --win --dir",
    "build:linux": "electron-builder --linux",
    "build:linux:dir": "electron-builder --linux --dir"
  },
  "keywords": [
    "employee-monitoring",
    "screenshot",
    "tracking"
  ],
  "license": "ISC",
  "build": {
    "appId": "com.employeemonitor.app",
    "productName": "Employee Monitor",
    "copyright": "Copyright (c) 2024",
    "npmRebuild": false,
    "directories": {
      "output": "dist",
      "buildResources": "desktop-app/assets"
    },
    "files": [
      "desktop-app/**/*",
      "!desktop-app/.env",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop-app/assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "desktop-app/assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Employee Monitor",
      "runAfterFinish": true,
      "installerIcon": "desktop-app/assets/icon.ico",
      "uninstallerIcon": "desktop-app/assets/icon.ico"
    },
    "portable": {
      "artifactName": "EmployeeMonitor-Portable-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "desktop-app/assets/icon.png",
      "category": "Utility",
      "desktop": {
        "StartupWMClass": "employee-monitoring-system"
      }
    },
    "deb": {
      "depends": [
        "xdotool",
        "libxss1",
        "xinput",
        "libappindicator3-1",
        "libnotify4"
      ],
      "artifactName": "EmployeeMonitor-${version}.${ext}",
      "maintainer": "Aryav Gupta <aryavgupta2005@gmail.com>"
    }
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^27.1.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1"
  },
  "optionalDependencies": {
    "aws-sdk": "^2.1478.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.2",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  }
}
